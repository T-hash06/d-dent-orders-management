{
	"name": "@d-dentaditamentos/web",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "react-router build",
		"dev": "react-router dev --host",
		"drizzle-kit": "drizzle-kit --config './app/features/.server/drizzle/drizzle.config.ts'",
		"drizzle-kit:generate": "drizzle-kit generate --config './app/features/.server/drizzle/drizzle.config.ts'",
		"drizzle-kit:migrate": "drizzle-kit migrate --config './app/features/.server/drizzle/drizzle.config.ts'",
		"drizzle-kit:push": "drizzle-kit push --config './app/features/.server/drizzle/drizzle.config.ts'",
		"drizzle-kit:studio": "drizzle-kit studio --config './app/features/.server/drizzle/drizzle.config.ts'",
		"drizzle-kit:seed": "tsx ./app/features/.server/drizzle/drizzle.seed.ts",
		"machine-translate": "inlang machine translate --project project.inlang",
		"inlang": "inlang",
		"start": "react-router-serve ./build/server/index.js",
		"type-check": "react-router typegen && tsc"
	},
	"dependencies": {
		"@casl/ability": "^6.8.0",
		"@d-dentaditamentos/ui": "workspace:*",
		"@hugeicons/core-free-icons": "^4.0.0",
		"@hugeicons/react": "^1.1.5",
		"@libsql/client": "^0.17.0",
		"@react-router/node": "7.13.1",
		"@react-router/serve": "7.13.1",
		"@tanstack/match-sorter-utils": "^8.19.4",
		"@tanstack/react-form": "^1.28.4",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-table": "^8.21.3",
		"@trpc/client": "^11.12.0",
		"@trpc/server": "^11.12.0",
		"@trpc/tanstack-react-query": "^11.12.0",
		"better-auth": "^1.5.4",
		"date-fns": "^4.1.0",
		"dotenv": "^17.3.1",
		"drizzle-orm": "^0.45.1",
		"isbot": "^5.1.31",
		"next-themes": "^0.4.6",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router": "7.13.1",
		"recharts": "2.15.4",
		"superjson": "^2.2.6",
		"zod": "^4.3.6",
		"zustand": "^5.0.11"
	},
	"devDependencies": {
		"@babel/preset-typescript": "^7.28.5",
		"@inlang/cli": "^3.0.0",
		"@inlang/paraglide-js": "^2.13.2",
		"@react-router/dev": "7.13.1",
		"@tailwindcss/vite": "^4.2.1",
		"@types/node": "^25.3.5",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"babel-plugin-react-compiler": "^1.0.0",
		"drizzle-kit": "^0.31.9",
		"tailwindcss": "^4.2.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.2",
		"vite": "^7.1.7",
		"vite-plugin-babel": "^1.6.0",
		"vite-tsconfig-paths": "^6.1.1"
	}
}
